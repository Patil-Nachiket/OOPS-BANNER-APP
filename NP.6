/**
 * ============================================================================
 *  Project      : OOPS Banner Application
 *  Use Case     : UC6 - Modular Character Pattern Generation
 *  Description  : Generates ASCII banner using reusable helper methods
 *                 for each character (O, P, S).
 *
 *  Author       : Nachiket Patil
 *  Version      : 3.0
 * ============================================================================
 */

public final class OOPSBannerApp {

    private static final int HEIGHT = 5;

    private OOPSBannerApp() {
        throw new UnsupportedOperationException("Utility class");
    }

    public static void main(String[] args) {

        String[][] banner = buildBanner();
        renderBanner(banner);
    }

    /**
     * Builds the banner dynamically using helper methods.
     */
    private static String[][] buildBanner() {

        String[] o = buildO();
        String[] p = buildP();
        String[] s = buildS();

        String[][] banner = new String[HEIGHT][1];

        for (int i = 0; i < HEIGHT; i++) {
            banner[i][0] = o[i] + "  " + o[i] + "  " + p[i] + "  " + s[i];
        }

        return banner;
    }

    /**
     * Renders banner using loop-based system.
     */
    private static void renderBanner(String[][] banner) {
        for (String[] row : banner) {
            System.out.println(String.join("", row));
        }
    }

    /* ================= Character Pattern Methods ================= */

    private static String[] buildO() {
        return new String[]{
                " OOO ",
                "O   O",
                "O   O",
                "O   O",
                " OOO "
        };
    }

    private static String[] buildP() {
        return new String[]{
                "PPP  ",
                "P   P",
                "PPP  ",
                "P    ",
                "P    "
        };
    }

    private static String[] buildS() {
        return new String[]{
                " SSS ",
                "S    ",
                " SSS ",
                "    S",
                " SSS "
        };
    }
}
