/**
 * OOPSBannerApp
 * UC2: ASCII Art Banner - Brute Force Method
 */
public class OOPSBannerApp {
    public static void main(String[] args) {
        // Line 1: Top of O, O, P, S
        System.out.println(" **** " + "  " + " **** " + "  " + " *****" + "  " + "  **** ");
        
        // Line 2: Sides of O, O, P and start of S
        System.out.println("* *" + "  " + "* *" + "  " + "* *" + "  " + " * ");
        
        // Line 3: Sides
        System.out.println("* *" + "  " + "* *" + "  " + "* *" + "  " + "  *** ");
        
        // Line 4: Middle of P and S
        System.out.println("* *" + "  " + "* *" + "  " + "***** " + "  " + "     * ");
        
        // Line 5: Bottom of P
        System.out.println("* *" + "  " + "* *" + "  " + "* " + "  " + "     * ");
        
        // Line 6: 
        System.out.println("* *" + "  " + "* *" + "  " + "* " + "  " + "* * ");
        
        // Line 7: Bottom cap
        System.out.println(" **** " + "  " + " **** " + "  " + "* " + "  " + " **** ");
    }
}
